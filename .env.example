# ─── Copy this file to .env and fill in the values ────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=frame
POSTGRES_PASSWORD=frame
POSTGRES_DB=frame_erd

# ── JWT  (generate with: openssl rand -hex 32) ────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_very_long_random_string
JWT_REFRESH_SECRET=change_me_refresh_secret_very_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── GitHub OAuth  (optional — leave blank to disable GitHub login) ─────────────
# Create an OAuth app at https://github.com/settings/developers
# Callback URL must match GITHUB_CALLBACK_URL below
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost/api/auth/github/callback

# ── App URLs ──────────────────────────────────────────────────────────────────
# FRONTEND_URL is used by the backend for CORS — must match what users open in browser
FRONTEND_URL=http://localhost
# Port the frontend nginx container is exposed on the host (default 80)
APP_PORT=80

# ── AI  (optional — leave blank to disable AI DBML generation) ────────────────
ANTHROPIC_API_KEY=
