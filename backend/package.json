{
	"name": "frame-backend",
	"version": "0.1.0",
	"description": "Frame ERD Backend",
	"author": "",
	"private": true,
	"license": "MIT",
	"scripts": {
		"build": "nest build",
		"start": "node dist/main",
		"dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:studio": "prisma studio",
		"db:format": "prisma format",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"format": "prettier --write \"src/**/*.ts\" \"prisma.config.ts\" \"*.json\"",
		"format:check": "prettier --check \"src/**/*.ts\" \"prisma.config.ts\" \"*.json\""
	},
	"dependencies": {
		"@nestjs/common": "^11.1.17",
		"@nestjs/config": "^4.0.3",
		"@nestjs/core": "^11.1.17",
		"@nestjs/platform-express": "^11.1.17",
		"@prisma/adapter-pg": "^7.5.0",
		"@prisma/client": "^7.5.0",
		"bcryptjs": "^3.0.3",
		"cookie-parser": "^1.4.7",
		"jsonwebtoken": "^9.0.3",
		"nestjs-zod": "^5.1.1",
		"pg": "^8.20.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.16",
		"@nestjs/schematics": "^11.0.9",
		"@nestjs/testing": "^11.1.17",
		"@types/bcryptjs": "^3.0.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.18.0",
		"jest": "^30.3.0",
		"prettier": "^3.8.1",
		"prisma": "^7.5.0",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3"
	}
}
