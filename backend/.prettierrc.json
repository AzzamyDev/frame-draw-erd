{
	"$schema": "https://json.schemastore.org/prettierrc",
	"semi": true,
	"singleQuote": true,
	"trailingComma": "all",
	"printWidth": 100,
	"tabWidth": 3,
	"useTabs": true,
	"endOfLine": "lf",
	"arrowParens": "always",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"quoteProps": "as-needed",
	"overrides": [
		{
			"files": "*.md",
			"options": { "proseWrap": "preserve" }
		}
	]
}
